# 金融即時偵測系統 - 環境變數範本
# 複製此檔案為 .env 並填入你的密鑰
# ⚠️ 不要提交 .env 到 Git (已在 .gitignore 中)

# ==================== AI 分析 ====================
# Claude API (Anthropic) - 必填
# 取得: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Gemini API (Google) - 預設使用
# 取得: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# 預設 AI 模型: gemini（推薦免費使用）或 claude
DEFAULT_AI_MODEL=gemini

# ==================== 新聞源 ====================
# NewsAPI - 必填
# 取得: https://newsapi.org
NEWS_API_KEY=your_newsapi_key_here

# ==================== 通知服務 ====================
# LINE Notify Token - 可選 (已棄用，建議改用 LINE Messaging API)
# 取得: https://notify-bot.line.me/my/
LINE_NOTIFY_TOKEN=your_line_notify_token_here

# LINE Messaging API - 可選 (用於緊急警報推播)
# 1. 前往 LINE Developers Console: https://developers.line.biz/
# 2. 建立 Provider → 建立 Messaging API channel
# 3. 在 channel 頁面取得 Channel access token (long-lived)
# 4. LINE_TARGET_ID: 個人 User ID 從 LINE Developers Console → 你的帳號圖示右上角
#    或在 Messaging API 設定 webhook，發訊息給 bot 後從 webhook event 取得 userId
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here
LINE_TARGET_ID=your_line_user_id_here
# 推播門檻: critical（僅緊急）| high（高＋緊急）| all（所有警報）
LINE_NOTIFY_MIN_SEVERITY=critical

# LINE Channel Secret - 用於 LINE Bot Webhook 簽名驗證（Reply API 模式，免費無月額限制）
# 在 LINE Developers Console → Messaging API → Channel secret 取得
# 設定後，使用者傳訊給 Bot 即可收到最新警報（不計入 200 則月額）
LINE_CHANNEL_SECRET=your_line_channel_secret_here

# Discord Webhook - 可選（完全免費、無訊息數限制）
# 在 Discord 頻道設定 → 整合 → Webhook → 建立 Webhook → 複製 URL
DISCORD_WEBHOOK_URL=

# Email SMTP - 可選 (Gmail 推薦)
# Gmail 設定: 啟用兩步驟驗證，建立應用程式密碼
# https://myaccount.google.com/apppasswords
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SENDER=your_email@gmail.com
EMAIL_PASSWORD=your_app_specific_password
EMAIL_RECIPIENT=recipient@example.com

# ==================== Google Sheets ====================
# 服務帳戶 JSON 檔案 - 可選 (用於位置暴險/新聞存檔)
# 建立: Google Cloud Console → 建立服務帳戶 → 下載 JSON
GOOGLE_SHEETS_CREDENTIALS_FILE=credentials.json

# Google Sheets 試算表 ID - 可選
# 從分享連結複製: https://docs.google.com/spreadsheets/d/{ID}
GOOGLE_SHEETS_SPREADSHEET_ID=

# 工作表名稱
GOOGLE_SHEETS_POSITION_SHEET=positions        # 持倉資料表
GOOGLE_SHEETS_NEWS_SHEET=news_archive         # 新聞存檔表

# Google Apps Script Web App URL（取代 Service Account，較簡單）
# GAS 部署後貼上 URL，格式: https://script.google.com/macros/s/.../exec
GOOGLE_APPS_SCRIPT_URL=your_gas_url_here

# ==================== 資料庫 ====================
DATABASE_URL=sqlite:///./data/financial_radar.db

# ==================== 排程設定 ====================
# 雷達掃描間隔 (分鐘)
RADAR_INTERVAL_MINUTES=5

# 市場檢查間隔 (分鐘)
MARKET_CHECK_INTERVAL_MINUTES=60

# 每日新聞蒐集時間 (小時, 24 小時制)
NEWS_SCHEDULE_HOUR=8

# 每日新聞蒐集時間 (分鐘)
NEWS_SCHEDULE_MINUTE=0

# ==================== 開發設定 (可選) ====================
# 日誌級別: DEBUG|INFO|WARNING|ERROR
LOG_LEVEL=INFO

# 環境: development|production
ENVIRONMENT=production

# 開啟 debug 模式
DEBUG=false
