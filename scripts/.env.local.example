# notebooklm_hourly.py 設定範例
# 複製此檔為 .env.local 並填入實際值

# VM 的 API 位址（不含結尾斜線）
API_BASE_URL=http://http://34.23.154.194:8000

# NotebookLM Notebook ID（從 notebooklm.google.com 的 URL 取得）
NOTEBOOK_ID=8476ff20-89d8-436a-9520-9da4f0cfd5c6

# 分析結果是否同時透過 VM 推播 LINE（true/false）
RESULT_PUSH_LINE=false

# 回溯時間（小時），預設 1
HOURS_BACK=12

# 最低嚴重度：critical（只有緊急）或 high（緊急+高風險）
MIN_SEVERITY=high
